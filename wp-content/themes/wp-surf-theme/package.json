{
	"name": "wp-surf-theme",
	"title": "WP SURF Theme",
	"url": "https://wordpress.org/themes/wp-surf-theme/",
	"author": {
		"name": "SURF B.V.",
		"email": "info@surf.nl",
		"url": "https://www.surf.nl/"
	},
	"copyright": "2025",
	"version": "1.0",
	"bugs": {
		"email": "support@surf.nl"
	},
	"private": true,
	"type": "module",
	"scripts": {
		"start": "npm run serve",
		"build": "vite build --config vite/vite.config.js",
		"watch": "vite build --config vite/vite.config.js --watch",
		"serve": "vite  --config vite/vite.config.js",
		"compile-views": "php ../../../scripts/compile-views",
		"prepoedit": "npm run compile-views",
		"poedit": "open -a poedit languages/nl_NL.po",
		"i18n:jsx": "node vite/plugins/jsx-translations.js",
		"jsx-fix": "npm run i18n:jsx"
	},
	"devDependencies": {
		"autoprefixer": "^10.4.8",
		"eslint": "^8.20.0",
		"eslint-config-standard": "^17.0.0",
		"eslint-plugin-react": "^7.30.1",
		"glob": "^8.0.3",
		"pofile": "^1.1.3",
		"postcss-prefixwrap": "^1.31.0",
		"postcss-scss": "^4.0.4",
		"sass": "^1.54.0",
		"sass-mq": "^6.0.0",
		"svgo": "^2.8.0",
		"vite": "^3.0.3",
		"vite-plugin-eslint": "^1.7.0",
		"vite-plugin-full-reload": "^1.0.3",
		"vite-plugin-stylelint": "^3.0.4"
	},
	"dependencies": {
		"@fortawesome/fontawesome-pro": "^6.1.1",
		"@oddbird/css-anchor-positioning": "^0.9.0",
		"@oddbird/popover-polyfill": "^0.6.1",
		"array-move": "^4.0.0",
		"body-scroll-lock": "^4.0.0-beta.0",
		"js-cookie": "^3.0.1",
		"luminous-lightbox": "^2.4.0",
		"normalize.css": "^8.0.1",
		"query-string": "^7.0.0",
		"react": "^17.0.2",
		"react-dom": "^17.0.2",
		"react-select": "^5.2.1",
		"slugify": "^1.6.6",
		"swr": "^1.3.0",
		"tiny-slider": "^2.9.4"
	},
	"stylelint": {
		"rules": {
			"selector-max-compound-selectors": 10
		}
	}
}
