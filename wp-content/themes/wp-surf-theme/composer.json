{
	"name" : "surf/wp-surf-theme",
	"description" : "WP SURF Theme",
	"autoload" : {
		"psr-4" : {
			"SURF\\" : "includes"
		}
	},
	"require" : {
		"filp/whoops" : "^2.14",
		"firebase/php-jwt" : "^6.2",
		"guzzlehttp/guzzle" : "^7.4",
		"illuminate/cache" : "^9.2.0",
		"illuminate/collections" : "^9.2.0",
		"illuminate/container" : "^9.2.0",
		"illuminate/http" : "^9.2.0",
		"illuminate/routing" : "^9.2.0",
		"illuminate/support" : "^9.2.0",
		"illuminate/view" : "^9.2.0",
		"mpdf/mpdf" : "^8.1",
		"phpoffice/phpspreadsheet" : "^1.27",
		"smalot/pdfparser" : "^2.2",
		"spatie/schema-org" : "^3.13",
		"vlucas/phpdotenv" : "^5.6"
	},
	"require-dev" : {
		"fakerphp/faker" : "^1.24",
		"friendsofphp/php-cs-fixer" : "^3.0",
		"symfony/var-dumper" : "^5.3",
		"wp-coding-standards/wpcs" : "^3.0"
	},
	"config" : {
		"sort-packages" : true,
		"platform" : {
			"php" : "8.2.0"
		},
		"allow-plugins" : {
			"dealerdirect/phpcodesniffer-composer-installer" : true
		}
	}
}
